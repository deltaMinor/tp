@startuml
!include style.puml
skinparam ClassFontColor #000000
skinparam ClassBorderColor #000000
skinparam ClassBackgroundColor #FFFFAA

title After command "clear"

package States <<rectangle>> {
    class State1 as "<u>s0:Snapshot</u>"
    class State2 as "<u>s1:Snapshot</u>"
    class State3 as "<u>s3:Snapshot</u>"
}

State1 -[hidden]right-> State2
State2 -[hidden]right-> State3

class Pointer as "snapshotPosition" #FFFFFF

Pointer -up-> State3
note right on link: Snapshot s2 deleted.
@end
